*{
    background-color: #1f1f1f;
    border: 1px solid #1f1f1f;
    image: url(":/ImagesTopToolBar/DarkTheme/DarkThemeForToolBars/FolderIco.png");
}


*:hover{
    background-color: #3d3d3d;;
    border: 1px solid #707070;
}

*:pressed{
    background-color: #2e2e2e;
    border: 1px solid #707070;
    image: url(":/ImagesTopToolBar/DarkTheme/DarkThemeForToolBars/FolderIco.png");
}

